{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vp dev",
    "build": "npm run typecheck && vp build",
    "preview": "vp preview",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsgo --noEmit",
    "build:types": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@reatom/core": "^1000.15.1",
    "@reatom/jsx": "^1000.1.0",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@spiriit/vite-plugin-svg-spritemap": "^6.0.0",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260307.1",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "npm@11.11.1",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
