{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsgo --noEmit",
    "build:types": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@reatom/core": "^1000.15.1",
    "@reatom/jsx": "^1000.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260307.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0-beta.16"
  },
  "overrides": {
    "vite": "^8.0.0-beta.16"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
